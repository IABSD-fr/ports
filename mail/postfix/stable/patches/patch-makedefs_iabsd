Add IABSD support.

Index: makedefs
--- makedefs.orig
+++ makedefs
@@ -355,6 +355,15 @@
 		;;
  DragonFly.*)	SYSTYPE=DRAGONFLY
 		;;
+  IABSD.*)	SYSTYPE=OPENBSD
+		: ${CC=cc}
+		: ${SHLIB_SUFFIX=.so.1.0}
+		: ${SHLIB_CFLAGS=-fPIC}
+		: ${SHLIB_LD="${CC} -shared"' -Wl,-soname,${LIB}'}
+		: ${SHLIB_RPATH='-Wl,-rpath,${SHLIB_DIR}'}
+		: ${SHLIB_ENV="LD_LIBRARY_PATH=`pwd`/lib"}
+		: ${PLUGIN_LD="${CC} -shared"}
+		;;
   OpenBSD.*)	SYSTYPE=OPENBSD
 		: ${CC=cc}
 		: ${SHLIB_SUFFIX=.so.1.0}
